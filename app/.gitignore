# 环境变量（含 API Key，绝不提交）
.env
*.env
.env.*
!.env.example

# 编辑器临时文件
*.swp
*.swo
.DS_Store

# 知识库向量索引（本地生成，体积大）
knowledge/.chroma/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# 沙箱缺陷 mock 数据（运行时生成）
eval/mock_defects.json

# 跨会话记忆（个人数据，不提交）
memory/
!memory/.gitkeep

# Agent 输出文件（运行时生成）
output/
!output/.gitkeep

# SQLite 数据库
# 生产环境可以加回此行以忽略。Demo 用途时保留 qa_team.db 在 git 中，
# 这样部署后 mock 数据（Agent / 测试套件 / 考试记录）可直接使用。
# web/qa_team.db
