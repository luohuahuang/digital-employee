# ── LLM Provider (choose one, or fill both) ──────────────────────────────────
# Switch provider: just change this line, no code modification needed
LLM_PROVIDER=anthropic     # anthropic | openai

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# GPT-4 (OpenAI)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=                   # Optional, for proxy or Azure OpenAI

# ── Model (optional, uses provider default if not set) ─────────────────────────
# Anthropic default: claude-sonnet-4-6
# OpenAI default: gpt-4o
# MODEL_NAME=gpt-4o

# ── Knowledge Base Embedding ──────────────────────────────────────────────────
# The knowledge base always uses OpenAI text-embedding-3-small for vector search,
# regardless of which LLM provider is selected above.
# EMBEDDING_API_KEY is the dedicated key for this.  If not set, it falls back to
# OPENAI_API_KEY — so when using OpenAI for both LLM and embedding, one key suffices.
#
# Using Claude as LLM → set EMBEDDING_API_KEY (OPENAI_API_KEY is not needed)
# Using GPT-4 as LLM  → EMBEDDING_API_KEY can be omitted; OPENAI_API_KEY is reused
#
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxx   # OpenAI key for knowledge base embedding

# Optionally override the embedding model (default: text-embedding-3-small)
# EMBEDDING_MODEL=text-embedding-3-small

# ── Confluence Integration (optional) ────────────────────────────────────────
# If not set, search_confluence / save_confluence_page tools will return a notice, system still works
#
# Choose authentication method based on your company's Confluence type:
#
# [Method A] Self-hosted Confluence (Server / Data Center) → Use PAT
#   Go to avatar in top-right of Confluence → Profile → Personal Access Tokens → Create token
# CONFLUENCE_AUTH_TYPE=pat
# CONFLUENCE_BASE_URL=https://confluence.yourcompany.com
# CONFLUENCE_API_TOKEN=your_personal_access_token
# (PAT mode does not need CONFLUENCE_USERNAME)
#
# [Method B] Atlassian Cloud (xxx.atlassian.net) → Use Basic Auth
#   Token generation: https://id.atlassian.com/manage-profile/security/api-tokens
# CONFLUENCE_AUTH_TYPE=basic
# CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
# CONFLUENCE_USERNAME=your@email.com
# CONFLUENCE_API_TOKEN=your_atlassian_api_token

# ── Jira Integration (optional) ───────────────────────────────────────────────
# If not set, search_jira / get_jira_issue / create_jira_issue tools will return a notice, system still works
#
# [Method A] Self-hosted Jira (Server / Data Center) → Use PAT
#   Go to avatar in top-right of Jira → Profile → Personal Access Tokens → Create token
# JIRA_AUTH_TYPE=pat
# JIRA_BASE_URL=https://jira.yourcompany.com
# JIRA_API_TOKEN=your_personal_access_token
# (PAT mode does not need JIRA_USERNAME)
#
# [Method B] Atlassian Cloud (xxx.atlassian.net) → Use Basic Auth
#   Token generation: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_AUTH_TYPE=basic
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_USERNAME=your@email.com
# JIRA_API_TOKEN=your_atlassian_api_token
#
# Default project key for create_jira_issue when no project_key parameter is provided
# DEFAULT_JIRA_PROJECT=SHOP

# ── GitLab Integration (optional) ─────────────────────────────────────────────
# Used to fetch MR diffs for regression scope analysis.
# Token: GitLab → top-right avatar → Preferences → Access Tokens → required scope: read_api
# GITLAB_BASE_URL=https://gitlab.yourcompany.com
# GITLAB_API_TOKEN=your_gitlab_private_token

# ── Web / Nginx Settings ──────────────────────────────────────────────────────
# PUBLIC_PORT: the port nginx listens on (default: 80)
# WEB_BASE_PATH: the URL prefix for the app (default: /digital-employee)
# WEB_PORT: internal FastAPI port, not exposed publicly (default: 8000)
# PUBLIC_PORT=80
# WEB_BASE_PATH=/digital-employee
# WEB_PORT=8000
